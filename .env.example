VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase content sync
# Leave these empty until Supabase is configured.
VITE_CONTENT_SOURCE=auto
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_CONTENT_LOCALE=nb
# Optional comma-separated allowlist for bootstrap access during migration.
VITE_SUPABASE_CONTENT_EDITORS=

# Admin auth mode: supabase (safe default) or local (dev only legacy fallback).
VITE_ADMIN_AUTH_MODE=supabase

# Structured admin editor + live preview shell.
# Default is ON; set to false/0/no/off only if you need to fall back to JSON-only editing.
VITE_ADMIN_STRUCTURED_EDITOR=true

# Legacy local admin fallback (development only).
# Generate the hash by running the snippet in browser console.
# VITE_ADMIN_HASH=your_pbkdf2_hash_here
VITE_ADMIN_SALT=gw-static-salt-v1
