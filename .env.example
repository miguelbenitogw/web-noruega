VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Supabase content sync
# Leave these empty to keep the current local-only behavior.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_CONTENT_LOCALE=nb
# Optional comma-separated allowlist for editors.
VITE_SUPABASE_CONTENT_EDITORS=
# Set to "supabase" to require Supabase auth in /admin and persist globally.
VITE_ADMIN_AUTH_MODE=local

# Admin panel security
# VITE_ADMIN_HASH   → PBKDF2-SHA256 hex hash of your admin password (200,000 iterations)
# VITE_ADMIN_SALT   → salt used during hashing (keep consistent between hash generation and runtime)
# Generate the hash by running the snippet in browser console (see README or AdminPage.jsx comments)
VITE_ADMIN_HASH=your_pbkdf2_hash_here
VITE_ADMIN_SALT=gw-static-salt-v1
