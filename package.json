{
  "name": "web-noruega",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "npm run test:anchors && npm run test:admin-editor && npm run test:news-mvp && npm run test:inline-links && npm run test:linkable-anchors && npm run test:content-assets && npm run test:news-assets",
    "test:anchors": "node scripts/check-anchors.mjs",
    "test:admin-editor": "node src/components/admin/__tests__/structuredFields.test.mjs",
    "test:news-mvp": "node --experimental-specifier-resolution=node src/lib/__tests__/newsMvpContracts.test.mjs",
    "test:inline-links": "node --experimental-specifier-resolution=node src/utils/__tests__/inlineLinkParser.test.js",
    "test:linkable-anchors": "node --experimental-specifier-resolution=node src/lib/__tests__/linkableAnchors.test.mjs",
    "test:content-assets": "node --experimental-specifier-resolution=node src/lib/__tests__/contentAssetsService.test.mjs",
    "test:news-assets": "node --experimental-specifier-resolution=node src/lib/__tests__/newsAssetResolution.test.mjs",
    "prebuild": "node scripts/generate-sitemap.mjs",
    "build": "vite build",
    "check": "npm test && npm run lint",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.100.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-ga4": "^2.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.0"
  }
}
